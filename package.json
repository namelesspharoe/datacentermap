{
  "name": "datacenter-officials-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "copy-data": "node scripts/copy-data.mjs",
    "fetch:states": "node scripts/fetch-us-states-geojson.mjs",
    "build:aqueduct": "node scripts/build-aqueduct-county-risk.mjs",
    "fetch:officials": "node scripts/fetch-county-officials.mjs",
    "predev": "node scripts/copy-data.mjs && node scripts/build-aqueduct-county-risk.mjs",
    "prebuild": "node scripts/copy-data.mjs && node scripts/build-aqueduct-county-risk.mjs",
    "dev": "vite",
    "start-api": "node server/officials-proxy.mjs",
